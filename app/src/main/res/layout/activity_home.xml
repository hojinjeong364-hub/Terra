<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="https://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terra_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/homeTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textColor="@color/terra_text"
        android:textSize="24sp"
        android:textStyle="bold"/>

     <TextView
        android:id="@+id/homeSummaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:marginTop="12dp"
        android:text="@string/home_summary"
        android:textColor="@color/terra_muted"
        android:textSize="14sp"/>
    
    <Button
        android:id="@+id/startFocusButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:marginTop="28dp"
        android:text="@string/start_focus" />

</LinearLayout>